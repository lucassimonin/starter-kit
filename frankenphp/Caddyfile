{
	{$CADDY_GLOBAL_OPTIONS}

	frankenphp {
		# En prod, FRANKENPHP_CONFIG="worker ./public/index.php" active le mode worker.
		{$FRANKENPHP_CONFIG}
	}
}

{$CADDY_EXTRA_CONFIG}

# SERVER_NAME = ton domaine (ex: cms.client.fr) → Caddy obtient automatiquement
# un certificat TLS Let's Encrypt. En local, mettre "localhost".
{$SERVER_NAME:localhost} {
	log {
		{$CADDY_SERVER_LOG_OPTIONS}
		output stderr
	}

	root public/
	encode zstd br gzip

	# Cache long pour les assets versionnés d'AssetMapper (public/assets/*)
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	{$CADDY_SERVER_EXTRA_DIRECTIVES}

	php_server {
		try_files {path} index.php
	}
}
