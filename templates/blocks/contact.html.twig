<section {% if data.anchor|default('') %}id="{{ data.anchor }}"{% endif %} class="scroll-mt-24 border-t border-line py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="grid gap-12 lg:grid-cols-2">

            {# ---- Infos pratiques ---- #}
            <div class="reveal">
                {% if data.kicker %}
                    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-sage">{{ data.kicker }}</p>
                {% endif %}
                {% if data.title %}
                    <h2 class="mt-3 font-display text-3xl font-semibold text-forest">{{ data.title }}</h2>
                {% endif %}

                <address class="mt-8 space-y-5 not-italic text-sm">
                    {% if data.place_name or data.address %}
                        <div class="flex gap-4">
                            <i data-lucide="map-pin" class="mt-0.5 h-5 w-5 text-sage"></i>
                            <div>
                                {% if data.place_name %}<p class="font-semibold text-forest">{{ data.place_name }}</p>{% endif %}
                                {% if data.address %}<p class="mt-1 text-ink/65">{{ data.address|nl2br }}</p>{% endif %}
                                {% if data.access_note %}<p class="mt-2 text-xs text-ink/50">{{ data.access_note }}</p>{% endif %}
                            </div>
                        </div>
                    {% endif %}
                    {% if data.hours %}
                        <div class="flex gap-4">
                            <i data-lucide="clock" class="mt-0.5 h-5 w-5 text-sage"></i>
                            <div>
                                <p class="font-semibold text-forest">Horaires</p>
                                <p class="text-ink/65">{{ data.hours }}</p>
                            </div>
                        </div>
                    {% endif %}
                    {% if data.phone %}
                        <div class="flex gap-4">
                            <i data-lucide="phone" class="mt-0.5 h-5 w-5 text-sage"></i>
                            <div>
                                <a href="tel:{{ data.phone_href ?: data.phone }}" class="font-semibold text-forest hover:text-sage">{{ data.phone }}</a>
                            </div>
                        </div>
                    {% endif %}
                </address>

                {% if data.phone and data.call_label %}
                    <a href="tel:{{ data.phone_href ?: data.phone }}"
                       class="mt-6 inline-flex items-center gap-2 rounded-journal bg-forest px-6 py-3.5 text-sm font-semibold text-sand transition hover:bg-earth">
                        <i data-lucide="phone-call" class="h-4 w-4"></i>
                        {{ data.call_label }}
                    </a>
                {% endif %}
            </div>

            {# ---- Formulaire + carte ---- #}
            <div class="reveal">
                <form method="post" action="{{ path('front_contact') }}" class="rounded-journal border border-line bg-white p-6 sm:p-8">
                    <input type="hidden" name="_token" value="{{ csrf_token('contact') }}">
                    <input type="hidden" name="block" value="{{ block.id }}">
                    {# Honeypot anti-spam : invisible pour les humains #}
                    <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true">

                    {% if data.form_title %}
                        <h3 class="font-display text-xl font-semibold text-forest">{{ data.form_title }}</h3>
                    {% endif %}
                    {% if data.form_intro %}
                        <p class="mt-1 text-sm text-ink/55">{{ data.form_intro }}</p>
                    {% endif %}

                    {% for message in app.flashes('contact_success') %}
                        <p class="mt-4 rounded-journal bg-forest/10 px-4 py-3 text-sm text-forest" role="status">{{ message }}</p>
                    {% endfor %}
                    {% for message in app.flashes('contact_error') %}
                        <p class="mt-4 rounded-journal bg-red-50 px-4 py-3 text-sm text-red-700" role="alert">{{ message }}</p>
                    {% endfor %}

                    <div class="mt-6 grid gap-4 sm:grid-cols-2">
                        <div>
                            <label for="contact-name" class="text-xs font-medium uppercase tracking-wide text-ink/45">Nom</label>
                            <input id="contact-name" name="name" type="text" required
                                   class="mt-1.5 w-full rounded-journal border border-line bg-sand px-4 py-3 text-sm outline-none focus:border-forest focus:ring-2 focus:ring-forest/15">
                        </div>
                        <div>
                            <label for="contact-email" class="text-xs font-medium uppercase tracking-wide text-ink/45">E-mail</label>
                            <input id="contact-email" name="email" type="email" required
                                   class="mt-1.5 w-full rounded-journal border border-line bg-sand px-4 py-3 text-sm outline-none focus:border-forest focus:ring-2 focus:ring-forest/15">
                        </div>
                    </div>

                    {% set subjects = data.subjects|split_pairs %}
                    {% if subjects|length > 0 %}
                        <div class="mt-4">
                            <label for="contact-subject" class="text-xs font-medium uppercase tracking-wide text-ink/45">Sujet</label>
                            <select id="contact-subject" name="subject"
                                    class="mt-1.5 w-full rounded-journal border border-line bg-sand px-4 py-3 text-sm outline-none focus:border-forest">
                                <option value="">Choisir</option>
                                {% for subject in subjects %}
                                    <option>{{ subject.left }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    {% endif %}

                    <div class="mt-4">
                        <label for="contact-message" class="text-xs font-medium uppercase tracking-wide text-ink/45">Message</label>
                        <textarea id="contact-message" name="message" rows="4" required minlength="10"
                                  placeholder="Date, nombre de convives, horaire…"
                                  class="mt-1.5 w-full resize-y rounded-journal border border-line bg-sand px-4 py-3 text-sm outline-none focus:border-forest focus:ring-2 focus:ring-forest/15"></textarea>
                    </div>

                    <button type="submit" class="mt-6 inline-flex items-center gap-2 rounded-journal bg-forest px-6 py-3.5 text-sm font-semibold text-sand transition hover:bg-earth">
                        <i data-lucide="send" class="h-4 w-4"></i>
                        Envoyer
                    </button>
                </form>

                {% if data.map_embed %}
                    <div class="mt-6 overflow-hidden rounded-journal border border-line">
                        <iframe title="Carte — {{ data.place_name ?: 'localisation' }}" class="h-56 w-full sm:h-64" loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade" src="{{ data.map_embed }}"></iframe>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
