<section class="relative min-h-screen overflow-hidden">
    {% if data.image %}
        <div class="absolute inset-0 -z-10">
            <img src="{{ data.image }}" alt="{{ data.image_alt }}" class="h-full w-full object-cover" loading="eager">
            <div class="hero-overlay absolute inset-0"></div>
        </div>
    {% else %}
        <div class="absolute inset-0 -z-10 bg-forest"></div>
    {% endif %}

    <div class="relative mx-auto flex min-h-screen max-w-6xl flex-col justify-end px-4 pb-20 pt-28 sm:px-6 sm:pb-28">
        <div class="reveal max-w-3xl">
            {% if data.kicker %}
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-sand/80">{{ data.kicker }}</p>
            {% endif %}
            {% if data.title %}
                <h1 class="mt-4 font-display text-5xl font-semibold tracking-tight text-sand sm:text-7xl">{{ data.title }}</h1>
            {% endif %}
            {% if data.subtitle %}
                <p class="mt-3 text-sm font-medium uppercase tracking-[0.25em] text-sand/90 sm:text-base">{{ data.subtitle }}</p>
            {% endif %}
            {% if data.tagline %}
                <p class="mt-6 font-display text-2xl italic text-sand/95 sm:text-3xl">{{ data.tagline }}</p>
            {% endif %}
            {% if data.text %}
                <p class="mt-5 max-w-xl text-base leading-relaxed text-sand/85">{{ data.text }}</p>
            {% endif %}

            {% if data.primary_label or data.secondary_label %}
                <div class="mt-9 flex flex-col gap-3 sm:flex-row">
                    {% if data.primary_label %}
                        <a href="{{ data.primary_link ?: '#' }}"
                           class="inline-flex items-center justify-center gap-2 rounded-journal bg-sand px-6 py-3.5 text-sm font-semibold text-forest shadow-soft transition hover:bg-white">
                            <i data-lucide="utensils-crossed" class="h-4 w-4"></i>
                            {{ data.primary_label }}
                        </a>
                    {% endif %}
                    {% if data.secondary_label %}
                        <a href="{{ data.secondary_link ?: '#' }}"
                           class="inline-flex items-center justify-center gap-2 rounded-journal border border-sand/40 bg-forest/35 px-6 py-3.5 text-sm font-semibold text-sand backdrop-blur-sm transition hover:bg-forest/55">
                            <i data-lucide="calendar" class="h-4 w-4"></i>
                            {{ data.secondary_label }}
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
</section>
