<section class="scroll-mt-24 border-t border-line py-20 sm:py-28">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
        {% if data.kicker or data.title %}
            <div class="reveal">
                {% if data.kicker %}
                    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-sage">{{ data.kicker }}</p>
                {% endif %}
                {% if data.title %}
                    <h2 class="mt-3 font-display text-3xl font-semibold text-forest sm:text-4xl">{{ data.title }}</h2>
                {% endif %}
            </div>
        {% endif %}
        <div class="reveal prose-cms mt-8 text-sm text-ink/75 sm:text-base">
            {{ data.content|raw }}
        </div>
    </div>
</section>
