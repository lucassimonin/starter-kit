{% extends 'front/base.html.twig' %}

{% set site_name = setting('site_name', 'Mon site') %}
{% set post_url = app.request.schemeAndHttpHost ~ post_path(post) %}
{% set blog_index = post.locale == 'fr' ? path('front_blog') : path('front_blog_locale', {_locale: post.locale}) %}

{% block head_title %}{{ post.metaTitle ?: post.title }} — {{ site_name }}{% endblock %}

{% block seo %}
    {% set description = post.metaDescription ?: post.excerpt %}
    {% if description %}<meta name="description" content="{{ description }}">{% endif %}
    <link rel="canonical" href="{{ post_url }}">

    <meta property="og:type" content="article">
    <meta property="og:site_name" content="{{ site_name }}">
    <meta property="og:title" content="{{ post.metaTitle ?: post.title }}">
    {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
    <meta property="og:url" content="{{ post_url }}">
    {% if post.coverImage %}<meta property="og:image" content="{{ post.coverImage starts with 'http' ? post.coverImage : app.request.schemeAndHttpHost ~ post.coverImage }}">{% endif %}
    {% if post.publishedAt %}<meta property="article:published_time" content="{{ post.publishedAt|date('c') }}">{% endif %}
    <meta name="twitter:card" content="summary_large_image">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": {{ post.title|json_encode|raw }},
        "datePublished": "{{ post.publishedAt ? post.publishedAt|date('c') }}",
        "dateModified": "{{ post.updatedAt|date('c') }}",
        {% if post.coverImage %}"image": {{ (post.coverImage starts with 'http' ? post.coverImage : app.request.schemeAndHttpHost ~ post.coverImage)|json_encode|raw }},{% endif %}
        "publisher": { "@type": "Organization", "name": {{ site_name|json_encode|raw }} }
    }
    </script>
{% endblock %}

{% block body %}
    <article class="border-t border-line pb-20 pt-28 sm:pb-28 sm:pt-36">
        <div class="mx-auto max-w-3xl px-4 sm:px-6">
            <div class="reveal">
                <a href="{{ blog_index }}" class="text-xs font-semibold uppercase tracking-[0.2em] text-sage hover:text-forest">← Toutes les actualités</a>

                <div class="mt-6 flex items-center gap-3 text-xs text-ink/45">
                    {% if post.publishedAt %}
                        <time datetime="{{ post.publishedAt|date('Y-m-d') }}">{{ post.publishedAt|date('d/m/Y') }}</time>
                    {% endif %}
                    {% if post.category %}
                        <a href="{{ blog_index }}?categorie={{ post.category.slug }}"
                           class="rounded-journal border border-line px-2 py-0.5 font-semibold uppercase tracking-wider text-sage hover:border-forest">{{ post.category.name }}</a>
                    {% endif %}
                </div>

                <h1 class="mt-3 font-display text-3xl font-semibold text-forest sm:text-5xl">{{ post.title }}</h1>

                {% if post.excerpt %}
                    <p class="mt-5 text-base leading-relaxed text-ink/70 sm:text-lg">{{ post.excerpt }}</p>
                {% endif %}
            </div>

            {% if post.coverImage %}
                <div class="reveal mt-10 overflow-hidden rounded-journal border border-line">
                    <img src="{{ post.coverImage }}" alt="{{ post.coverAlt ?: post.title }}" class="w-full object-cover" loading="eager">
                </div>
            {% endif %}

            <div class="reveal prose-cms mt-10 text-sm text-ink/80 sm:text-base">
                {{ post.content|raw }}
            </div>
        </div>
    </article>
{% endblock %}
