<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for page in pages %}
    <url>
        <loc>{{ app.request.schemeAndHttpHost }}{{ page.isHomepage ? '/' : '/' ~ page.slug }}</loc>
        <lastmod>{{ page.updatedAt|date('Y-m-d') }}</lastmod>
        <priority>{{ page.isHomepage ? '1.0' : '0.7' }}</priority>
    </url>
{% endfor %}
</urlset>
