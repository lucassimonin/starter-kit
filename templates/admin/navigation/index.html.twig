{% extends 'admin/base.html.twig' %}
{% import 'admin/_icons.html.twig' as icons %}

{% block title %}Navigation{% endblock %}
{% block page_title %}Menus de navigation{% endblock %}

{% macro item_row(item) %}
    {% import 'admin/_icons.html.twig' as icons %}
    <form method="post" action="{{ path('admin_navigation_update', {id: item.id}) }}" class="flex flex-wrap items-center gap-2 px-5 py-3">
        <input type="hidden" name="_token" value="{{ csrf_token('admin') }}">
        <input type="hidden" name="location" value="{{ item.location }}">
        <input type="number" name="position" value="{{ item.position }}" class="w-16 rounded-lg border border-stone-200 px-2 py-1.5 text-center text-xs outline-none focus:border-emerald-600" title="Ordre">
        <input type="text" name="label" value="{{ item.label }}" class="w-40 rounded-lg border border-stone-200 px-3 py-1.5 text-sm outline-none focus:border-emerald-600" placeholder="Libellé">
        <input type="text" name="url" value="{{ item.url }}" class="min-w-40 flex-1 rounded-lg border border-stone-200 px-3 py-1.5 font-mono text-xs outline-none focus:border-emerald-600" placeholder="/page ou #ancre">
        <label class="flex items-center gap-1.5 text-xs font-semibold text-stone-500">
            <input type="checkbox" name="isButton" value="1" {{ item.isButton ? 'checked' }} class="h-3.5 w-3.5 accent-emerald-700"> Bouton
        </label>
        <button type="submit" class="rounded-lg border border-stone-200 px-3 py-1.5 text-xs font-bold text-stone-600 transition hover:border-emerald-600 hover:text-emerald-700">Enregistrer</button>
    </form>
    <form method="post" action="{{ path('admin_navigation_delete', {id: item.id}) }}" data-confirm="Supprimer ce lien ?" class="-mt-11 mr-5 flex justify-end pb-4">
        <input type="hidden" name="_token" value="{{ csrf_token('admin') }}">
        <button type="submit" class="rounded-lg p-1.5 text-stone-300 transition hover:bg-red-50 hover:text-red-600" title="Supprimer">{{ icons.icon('trash', 'h-4 w-4') }}</button>
    </form>
{% endmacro %}

{% block content %}
    <div class="grid gap-8 xl:grid-cols-2">
        {% for location, items in {'header': header_items, 'footer': footer_items} %}
            <div class="rounded-2xl border border-stone-200 bg-white">
                <div class="border-b border-stone-100 px-5 py-4">
                    <h2 class="text-sm font-bold">{{ location == 'header' ? 'Menu principal (header)' : 'Pied de page (footer)' }}</h2>
                </div>
                <div class="divide-y divide-stone-50">
                    {% for item in items %}
                        <div>{{ _self.item_row(item) }}</div>
                    {% else %}
                        <p class="px-5 py-6 text-center text-sm text-stone-400">Aucun lien.</p>
                    {% endfor %}
                </div>
                <form method="post" action="{{ path('admin_navigation_add') }}" class="flex flex-wrap items-center gap-2 border-t border-stone-100 bg-stone-50/60 px-5 py-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin') }}">
                    <input type="hidden" name="location" value="{{ location }}">
                    <input type="number" name="position" value="{{ items|length }}" class="w-16 rounded-lg border border-stone-200 px-2 py-1.5 text-center text-xs outline-none focus:border-emerald-600" title="Ordre">
                    <input type="text" name="label" required placeholder="Libellé" class="w-40 rounded-lg border border-stone-200 px-3 py-1.5 text-sm outline-none focus:border-emerald-600">
                    <input type="text" name="url" required placeholder="/page ou #ancre" class="min-w-40 flex-1 rounded-lg border border-stone-200 px-3 py-1.5 font-mono text-xs outline-none focus:border-emerald-600">
                    <label class="flex items-center gap-1.5 text-xs font-semibold text-stone-500">
                        <input type="checkbox" name="isButton" value="1" class="h-3.5 w-3.5 accent-emerald-700"> Bouton
                    </label>
                    <button type="submit" class="inline-flex items-center gap-1 rounded-lg bg-emerald-700 px-3.5 py-1.5 text-xs font-bold text-white transition hover:bg-emerald-800">
                        {{ icons.icon('plus', 'h-3.5 w-3.5') }} Ajouter
                    </button>
                </form>
            </div>
        {% endfor %}
    </div>
{% endblock %}
