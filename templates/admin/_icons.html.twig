{# Icônes SVG inline (stroke currentColor) — usage : {{ icons.icon('pages', 'h-4 w-4') }} #}
{% macro icon(name, class = 'h-4 w-4') %}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="{{ class }}" aria-hidden="true">
  {%- if name == 'dashboard' -%}
    <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
  {%- elseif name == 'pages' -%}
    <path d="M14 3H6a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V8z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 17h6"/>
  {%- elseif name == 'media' -%}
    <rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><path d="m21 16-4.5-4.5L8 20"/>
  {%- elseif name == 'mail' -%}
    <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>
  {%- elseif name == 'news' -%}
    <path d="M4 4h13a1 1 0 0 1 1 1v13a2 2 0 0 0 2 2H6a2 2 0 0 1-2-2Z"/><path d="M18 20a2 2 0 0 0 2-2V8"/><path d="M7 8h7M7 12h7M7 16h4"/>
  {%- elseif name == 'navigation' -%}
    <path d="M4 6h16M4 12h16M4 18h10"/>
  {%- elseif name == 'redirects' -%}
    <path d="M4 7h11a4 4 0 0 1 4 4v6"/><path d="m15 13 4 4 4-4" transform="translate(-4 0)"/>
  {%- elseif name == 'settings' -%}
    <path d="M4 8h10M18 8h2M4 16h2M10 16h10"/><circle cx="16" cy="8" r="2"/><circle cx="8" cy="16" r="2"/>
  {%- elseif name == 'logout' -%}
    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="m16 17 5-5-5-5"/><path d="M21 12H9"/>
  {%- elseif name == 'grip' -%}
    <circle cx="9" cy="6" r="1.3"/><circle cx="15" cy="6" r="1.3"/><circle cx="9" cy="12" r="1.3"/><circle cx="15" cy="12" r="1.3"/><circle cx="9" cy="18" r="1.3"/><circle cx="15" cy="18" r="1.3"/>
  {%- elseif name == 'plus' -%}
    <path d="M12 5v14M5 12h14"/>
  {%- elseif name == 'trash' -%}
    <path d="M4 7h16"/><path d="M10 11v6M14 11v6"/><path d="M6 7l1 13a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1l1-13"/><path d="M9 7V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3"/>
  {%- elseif name == 'eye' -%}
    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
  {%- elseif name == 'eye-off' -%}
    <path d="M2 12s3.5-7 10-7c2 0 3.8.7 5.3 1.6M22 12s-3.5 7-10 7c-2 0-3.8-.7-5.3-1.6"/><path d="m3 3 18 18"/>
  {%- elseif name == 'copy' -%}
    <rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
  {%- elseif name == 'external' -%}
    <path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
  {%- elseif name == 'chevron' -%}
    <path d="m6 9 6 6 6-6"/>
  {%- elseif name == 'check' -%}
    <path d="m5 13 4 4L19 7"/>
  {%- elseif name == 'home' -%}
    <path d="m3 11 9-8 9 8"/><path d="M5 10v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V10"/>
  {%- else -%}
    <circle cx="12" cy="12" r="9"/>
  {%- endif -%}
</svg>
{% endmacro %}
