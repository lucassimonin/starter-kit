<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Connexion — {{ setting('site_name', 'Starter CMS') }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
</head>
<body class="flex h-full items-center justify-center bg-stone-900 font-admin text-stone-900 antialiased">
<div class="w-full max-w-sm px-6">
    <div class="mb-6 text-center">
        <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-600 text-lg font-extrabold text-white">S</span>
        <h1 class="mt-4 text-xl font-bold text-white">{{ setting('site_name', 'Starter CMS') }}</h1>
        <p class="mt-1 text-sm text-stone-400">Espace d'administration</p>
    </div>

    <form method="post" class="rounded-2xl bg-white p-6 shadow-2xl">
        {% if error %}
            <p class="mb-4 rounded-lg bg-red-50 px-3 py-2.5 text-sm font-medium text-red-700">
                Identifiants incorrects, merci de réessayer.
            </p>
        {% endif %}

        <label for="username" class="mb-1.5 block text-[13px] font-semibold text-stone-700">Adresse e-mail</label>
        <input type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus
               class="mb-4 block w-full rounded-lg border border-stone-300 px-3 py-2.5 text-sm outline-none transition focus:border-emerald-600 focus:ring-2 focus:ring-emerald-600/15">

        <label for="password" class="mb-1.5 block text-[13px] font-semibold text-stone-700">Mot de passe</label>
        <input type="password" name="_password" id="password" autocomplete="current-password" required
               class="mb-5 block w-full rounded-lg border border-stone-300 px-3 py-2.5 text-sm outline-none transition focus:border-emerald-600 focus:ring-2 focus:ring-emerald-600/15">

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="w-full rounded-lg bg-emerald-700 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-emerald-800">
            Se connecter
        </button>
    </form>
</div>
</body>
</html>
