{% extends 'admin/base.html.twig' %}

{% block title %}Réglages{% endblock %}
{% block page_title %}Réglages du site{% endblock %}

{% block content %}
    <form method="post" class="mx-auto max-w-2xl">
        <input type="hidden" name="_token" value="{{ csrf_token('admin') }}">
        <div class="rounded-2xl border border-stone-200 bg-white p-6">
            {% for key, meta in fields %}
                <div class="mb-4">
                    {% if key == 'maintenance_mode' %}
                        <div class="flex items-start gap-2.5 rounded-xl border border-amber-200 bg-amber-50/60 p-3">
                            <input type="checkbox" id="setting-{{ key }}" name="{{ key }}" value="1" {{ values[key]|default('') == '1' ? 'checked' }}
                                   class="mt-0.5 h-4 w-4 rounded border-stone-300 accent-amber-600">
                            <div>
                                <label for="setting-{{ key }}" class="text-[13px] font-semibold text-stone-700">{{ meta[0] }}</label>
                                {% if meta[1] %}<p class="text-xs text-stone-400">{{ meta[1] }}</p>{% endif %}
                            </div>
                        </div>
                    {% else %}
                    <label for="setting-{{ key }}" class="mb-1.5 block text-[13px] font-semibold text-stone-700">{{ meta[0] }}</label>
                    <div {% if key == 'logo_url' %}data-media-field class="flex gap-2"{% endif %}>
                        <input type="text" id="setting-{{ key }}" name="{{ key }}" value="{{ values[key]|default('') }}"
                               class="block w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none transition focus:border-emerald-600 focus:ring-2 focus:ring-emerald-600/15">
                        {% if key == 'logo_url' %}
                            <button type="button" data-media-picker class="shrink-0 rounded-lg border border-stone-300 px-3.5 py-2 text-xs font-bold text-stone-600 transition hover:border-emerald-600 hover:text-emerald-700">Parcourir</button>
                        {% endif %}
                    </div>
                    {% if meta[1] %}<p class="mt-1 text-xs text-stone-400">{{ meta[1] }}</p>{% endif %}
                    {% endif %}
                </div>
            {% endfor %}
        </div>
        <button type="submit" class="mt-5 w-full rounded-xl bg-emerald-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-800">
            Enregistrer les réglages
        </button>
    </form>
{% endblock %}
