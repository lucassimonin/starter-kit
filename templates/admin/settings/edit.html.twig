{% extends 'admin/base.html.twig' %}

{% block title %}Réglages{% endblock %}
{% block page_title %}Réglages du site{% endblock %}

{% block content %}
    <form method="post" class="mx-auto max-w-2xl">
        <input type="hidden" name="_token" value="{{ csrf_token('admin') }}">
        <div class="rounded-2xl border border-stone-200 bg-white p-6">
            {% for key, meta in fields %}
                <div class="mb-4">
                    <label for="setting-{{ key }}" class="mb-1.5 block text-[13px] font-semibold text-stone-700">{{ meta[0] }}</label>
                    <input type="text" id="setting-{{ key }}" name="{{ key }}" value="{{ values[key]|default('') }}"
                           class="block w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none transition focus:border-emerald-600 focus:ring-2 focus:ring-emerald-600/15">
                    {% if meta[1] %}<p class="mt-1 text-xs text-stone-400">{{ meta[1] }}</p>{% endif %}
                </div>
            {% endfor %}
        </div>
        <button type="submit" class="mt-5 w-full rounded-xl bg-emerald-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-800">
            Enregistrer les réglages
        </button>
    </form>
{% endblock %}
