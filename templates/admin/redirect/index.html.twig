{% extends 'admin/base.html.twig' %}
{% import 'admin/_icons.html.twig' as icons %}

{% block title %}Redirections{% endblock %}
{% block page_title %}Redirections{% endblock %}

{% block content %}
    <form method="post" action="{{ path('admin_redirect_add') }}" class="mb-8 flex flex-wrap items-end gap-3 rounded-2xl border border-stone-200 bg-white p-5">
        <input type="hidden" name="_token" value="{{ csrf_token('admin') }}">
        <div class="min-w-52 flex-1">
            <label class="mb-1.5 block text-[13px] font-semibold text-stone-700">Ancienne URL (source)</label>
            <input type="text" name="source" required placeholder="/ancienne-page" class="block w-full rounded-lg border border-stone-300 px-3 py-2 font-mono text-xs outline-none focus:border-emerald-600">
        </div>
        <div class="min-w-52 flex-1">
            <label class="mb-1.5 block text-[13px] font-semibold text-stone-700">Nouvelle URL (cible)</label>
            <input type="text" name="target" required placeholder="/nouvelle-page ou https://…" class="block w-full rounded-lg border border-stone-300 px-3 py-2 font-mono text-xs outline-none focus:border-emerald-600">
        </div>
        <div>
            <label class="mb-1.5 block text-[13px] font-semibold text-stone-700">Type</label>
            <select name="statusCode" class="rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none focus:border-emerald-600">
                <option value="301">301 — permanente</option>
                <option value="302">302 — temporaire</option>
            </select>
        </div>
        <button type="submit" class="rounded-lg bg-emerald-700 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-emerald-800">Créer</button>
        <p class="w-full text-xs text-stone-400">Astuce : renommer le slug d'une page crée automatiquement la redirection 301 correspondante.</p>
    </form>

    <div class="overflow-hidden rounded-2xl border border-stone-200 bg-white">
        <table class="w-full text-left text-sm">
            <thead class="bg-stone-50 text-[11px] font-bold uppercase tracking-wider text-stone-400">
                <tr>
                    <th class="px-5 py-3">Source</th>
                    <th class="px-5 py-3">Cible</th>
                    <th class="px-5 py-3">Code</th>
                    <th class="px-5 py-3">Créée</th>
                    <th class="px-5 py-3 text-right"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-stone-100">
                {% for redirect in redirects %}
                    <tr class="transition hover:bg-stone-50/60">
                        <td class="px-5 py-3 font-mono text-xs">{{ redirect.source }}</td>
                        <td class="px-5 py-3 font-mono text-xs text-stone-500">{{ redirect.target }}</td>
                        <td class="px-5 py-3"><span class="rounded-full bg-stone-100 px-2 py-0.5 text-[11px] font-bold text-stone-600">{{ redirect.statusCode }}</span></td>
                        <td class="px-5 py-3 text-xs text-stone-400">{{ redirect.createdAt|date('d/m/Y') }}</td>
                        <td class="px-5 py-3 text-right">
                            <form method="post" action="{{ path('admin_redirect_delete', {id: redirect.id}) }}" data-confirm="Supprimer cette redirection ?" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin') }}">
                                <button type="submit" class="rounded-lg p-2 text-stone-400 transition hover:bg-red-50 hover:text-red-600">{{ icons.icon('trash', 'h-4 w-4') }}</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="px-5 py-10 text-center text-stone-400">Aucune redirection.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
