{% extends 'admin/base.html.twig' %}

{% block title %}{{ is_new ? 'Nouvel article' : post.title }}{% endblock %}

{% block page_title %}
    <span class="flex items-center gap-2.5">
        {{ is_new ? 'Nouvel article' : post.title }}
        {% if not is_new %}
            <span class="rounded-full px-2 py-0.5 text-[11px] font-bold {{ post.published ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800' }}">
                {{ post.published ? 'Publié' : 'Brouillon' }}
            </span>
        {% endif %}
    </span>
{% endblock %}

{% block header_actions %}
    {% if not is_new %}
        <a href="{{ post_path(post) }}" target="_blank"
           class="inline-flex items-center gap-1.5 rounded-lg border border-stone-300 px-3.5 py-2 text-[13px] font-bold text-stone-700 transition hover:bg-stone-50">
            {{ post.published ? 'Voir l\'article' : 'Prévisualiser' }}
        </a>
        <form method="post" action="{{ path('admin_post_publish', {id: post.id}) }}" class="inline">
            <input type="hidden" name="_token" value="{{ csrf_token('admin') }}">
            <button type="submit" class="rounded-lg {{ post.published ? 'border border-stone-300 text-stone-700 hover:bg-stone-50' : 'bg-emerald-700 text-white hover:bg-emerald-800' }} px-3.5 py-2 text-[13px] font-bold transition">
                {{ post.published ? 'Repasser en brouillon' : 'Publier' }}
            </button>
        </form>
    {% endif %}
{% endblock %}

{% block content %}
    <div class="mx-auto max-w-3xl">
        {{ form_start(form) }}
            <div class="rounded-2xl border border-stone-200 bg-white p-6">
                {{ form_row(form.title) }}
                {{ form_row(form.slug) }}
                {{ form_row(form.locale) }}
                {{ form_row(form.category) }}
                {{ form_row(form.coverImage) }}
                {{ form_row(form.coverAlt) }}
                {{ form_row(form.excerpt) }}
                {{ form_row(form.content) }}
            </div>

            <div class="mt-5 rounded-2xl border border-stone-200 bg-white p-6">
                <h2 class="mb-5 text-sm font-bold">SEO</h2>
                {{ form_row(form.metaTitle) }}
                {{ form_row(form.metaDescription) }}
            </div>

            <div class="mt-5 flex items-center justify-end gap-3">
                <a href="{{ path('admin_posts') }}" class="rounded-lg px-4 py-2.5 text-sm font-semibold text-stone-500 hover:text-stone-800">Retour</a>
                <button type="submit" class="rounded-lg bg-emerald-700 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-emerald-800">
                    Enregistrer
                </button>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
