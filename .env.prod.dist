# Variables de déploiement production — à copier en .env.prod (non versionné) :
#   cp .env.prod.dist .env.prod
#   docker compose --env-file .env.prod -f compose.prod.yaml up -d --build

# Domaine servi (TLS auto Let's Encrypt). "localhost" pour un test local.
SERVER_NAME=cms.mon-client.fr
DEFAULT_URI=https://cms.mon-client.fr

# Secret applicatif — générer avec : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=change_me

# Base de données MySQL (le service tourne dans le compose)
MYSQL_DATABASE=cms_starter
MYSQL_USER=cms
MYSQL_PASSWORD=change_me_user
MYSQL_ROOT_PASSWORD=change_me_root

# Envoi des emails (formulaire de contact) — SMTP réel en prod
# ex: smtp://user:pass@smtp.example.com:587
MAILER_DSN=smtp://user:pass@smtp.example.com:587

# Mise en place du schéma au démarrage : schema | migrate | none
AUTO_DB_SETUP=schema

# Passer à 1 UNIQUEMENT au premier déploiement pour charger la démo Bivouak
LOAD_FIXTURES=0
